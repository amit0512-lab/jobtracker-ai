# ═══════════════════════════════════════════════════════════
#                    JOBTRACKER AI - ENVIRONMENT CONFIG
# ═══════════════════════════════════════════════════════════

# Application Settings
APP_NAME=JobTracker
APP_ENV=development
DEBUG=True

# Security (IMPORTANT: Change SECRET_KEY in production!)
# Generate using: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256

# JWT Token Expiry
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
# For Docker: Use 'db' as hostname
# For local: Use 'localhost' with port 5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/jobtracker

# Redis Configuration
# For Docker: Use 'redis' as hostname
# For local: Use 'localhost'
REDIS_URL=redis://localhost:6379

# File Storage
# Set to True for local storage, False for AWS S3
USE_LOCAL_STORAGE=True

# AWS S3 Configuration (Only needed if USE_LOCAL_STORAGE=False)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BUCKET_NAME=jobtracker-resumes
AWS_REGION=us-east-1

# CORS Settings (Frontend URLs)
# In production, set to your actual frontend domain
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# ═══════════════════════════════════════════════════════════
#                         NOTES
# ═══════════════════════════════════════════════════════════
# 
# 1. Copy this file to .env and update the values
# 2. Never commit .env to version control
# 3. Generate a strong SECRET_KEY for production
# 4. Use environment-specific values for dev/staging/prod
# 5. Keep credentials secure and rotate them regularly
#
# ═══════════════════════════════════════════════════════════
